   "source": [
    "import heapq\n",
    "\n",
    "pq = []\n",
    "heapq.heappush(pq,10)\n",
    "heapq.heappush(pq,12)\n",
    "heapq.heappush(pq,1111)\n",
    "heapq.heappush(pq,3)\n",
    "heapq.heappush(pq,15)\n",
    "\n",
    "print(f\"当前堆结构: {pq}\")\n",
    "\n",
    "smallest = heapq.heappop(pq)\n",
    "print(f\"弹出的最小元素{smallest}\")\n"
   ],
